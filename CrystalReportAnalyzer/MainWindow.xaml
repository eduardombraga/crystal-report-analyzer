<Window x:Class="CrystalReportAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crystal Report Analyzer"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="580"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="#F0F2F5">

    <Window.Resources>

        <!-- ── Buttons ─────────────────────────────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#3498DB"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="18,9"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1F618D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExportButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#196F3D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Cards ──────────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"     Value="White"/>
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="Padding"        Value="16"/>
            <Setter Property="Margin"         Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1"
                                      Opacity="0.12" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeView ───────────────────────────────────────────── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Padding"    Value="3,3"/>
            <Setter Property="IsExpanded" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- header       -->
            <RowDefinition Height="Auto"/> <!-- file area    -->
            <RowDefinition Height="*"/>    <!-- main content -->
            <RowDefinition Height="28"/>   <!-- status bar   -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#1A252F">
            <DockPanel Margin="24,0">
                <Button DockPanel.Dock="Right"
                        Content="⚙ Configurações"
                        Click="Settings_Click"
                        VerticalAlignment="Center"
                        Padding="14,7"
                        FontSize="12"
                        Cursor="Hand"
                        Background="#2C3E50"
                        Foreground="#BDC3C7"
                        BorderThickness="1"
                        BorderBrush="#4A6278">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="#2C3E50"/>
                            <Setter Property="Foreground"      Value="#BDC3C7"/>
                            <Setter Property="BorderBrush"     Value="#4A6278"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding"         Value="14,7"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3D5166"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="Crystal Report Analyzer"
                           Foreground="White" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="análise de estrutura para migração"
                           Foreground="#7F8C8D" FontSize="12"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- ── File / Drop Zone ───────────────────────────────────── -->
        <Border Grid.Row="1"
                x:Name="DropZone"
                Background="#EAF4FB"
                BorderBrush="#AED6F1" BorderThickness="2"
                CornerRadius="8"
                Margin="12,10,12,4"
                Padding="16,10">
            <DockPanel>
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Abrir arquivo .rpt"
                        Click="OpenFile_Click"
                        DockPanel.Dock="Left"/>
                <TextBlock x:Name="FilePathText"
                           Text="Arraste um arquivo .rpt aqui ou clique em 'Abrir arquivo'"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           Foreground="#7F8C8D" FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ── Main Content ───────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="6,0,6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: report tree -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Estrutura do Relatório"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <TreeView x:Name="ReportTreeView"
                              BorderThickness="0"
                              Background="Transparent"
                              FontSize="13"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="#E0E4E8"/>

            <!-- Right panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Complexity score card -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Índice de Complexidade"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#2C3E50" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ScoreText"
                                           Text="—"
                                           FontSize="60" FontWeight="Bold"
                                           Foreground="#95A5A6"/>
                                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Border x:Name="LevelBadge"
                                            CornerRadius="20" Padding="14,5"
                                            Background="#95A5A6" Margin="0,0,0,6">
                                        <TextBlock x:Name="LevelText"
                                                   Text="—"
                                                   Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    </Border>
                                    <TextBlock x:Name="ScoreRange"
                                               Text=""
                                               Foreground="#95A5A6" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Breakdown mini-table -->
                        <Border Grid.Column="1"
                                Background="#F8F9FA" CornerRadius="8"
                                Padding="14,10" Margin="12,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Detalhamento"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#95A5A6" Margin="0,0,0,8"/>
                                <Grid x:Name="BreakdownGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Estatísticas -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Estatísticas"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2C3E50" Margin="0,0,0,10"/>

                        <!-- Dependências table at the bottom -->
                        <Border DockPanel.Dock="Bottom"
                                BorderBrush="#ECF0F1" BorderThickness="0,1,0,0"
                                Padding="0,10,0,0" Margin="0,10,0,0"
                                MaxHeight="200">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Dependências"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#95A5A6" Margin="0,0,0,6"/>
                                <ListView x:Name="DependenciesListView"
                                          BorderThickness="0"
                                          FontSize="12">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Objeto" Width="180"
                                                            DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="Tipo" Width="110"
                                                            DisplayMemberBinding="{Binding TypeLabel}"/>
                                            <GridViewColumn Header="Campos" Width="60"
                                                            DisplayMemberBinding="{Binding FieldCount}"/>
                                            <GridViewColumn Header="Localização" Width="200"
                                                            DisplayMemberBinding="{Binding Location}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Border>

                        <!-- Stats list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                            <ItemsControl x:Name="StatsPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1"
                                                Padding="2,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="13" Foreground="#555"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="#2980B9"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Export button row -->
                <Border Grid.Row="2" Padding="6,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="GenerateRazorButton"
                                Style="{StaticResource PrimaryButton}"
                                Content="Gerar .cshtml"
                                Click="GenerateRazor_Click"
                                IsEnabled="False"
                                Padding="22,10"
                                Margin="0,0,8,0"/>
                        <Button x:Name="ExportButton"
                                Style="{StaticResource ExportButton}"
                                Content="Exportar para JSON"
                                Click="ExportJson_Click"
                                IsEnabled="False"
                                Padding="22,10"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Status Bar ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#1A252F">
            <TextBlock x:Name="StatusText"
                       Text="Pronto. Abra ou arraste um arquivo .rpt para iniciar."
                       Foreground="#7F8C8D" FontSize="12"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>
    </Grid>
</Window>
